# 可选：微信公众号草稿箱推送
# WECHAT_APP_ID 填公众号后台的 AppID，通常以 wx 开头；不要填公众号ID / 原始ID（gh_...）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_DEFAULT_AUTHOR=TOMOAI
WECHAT_DEFAULT_THUMB_MEDIA_ID=
WECHAT_DEFAULT_CONTENT_SOURCE_URL=

# 可选：本地端口
PORT=8788

# 可选：后台 AI Provider，优先于前端保存的中转站配置
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=

# 也支持通用中转站变量名
# AI_PROVIDER_NAME=我的中转站
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.example.com/v1
# AI_MODEL=

# 可选：OpenRouter 免费路由测试
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_HTTP_REFERER=http://localhost:8788
# OPENROUTER_APP_TITLE=TOMOAI OPC Workbench

# 可选：Agnes AI 文本 + 图像模型
# AGNES_API_KEY=
# AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
# AGNES_MODEL=agnes-1.5-flash
# AGNES_IMAGE_MODEL=agnes-image-2.0-flash
